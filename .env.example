# Admin login (server-side only; never expose to the client)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Used to sign the admin session cookie (use a long random string)
ADMIN_SECRET_KEY=

# Public configuration (safe to expose to the client)
# Email address used by the Contact Me form (mailto: link)
NEXT_PUBLIC_CONTACT_EMAIL=
# Public URL to your CV (OneDrive, Google Drive, etc.)
NEXT_PUBLIC_CV_URL=
